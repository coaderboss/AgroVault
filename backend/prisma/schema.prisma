generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  password  String
  shopName  String?  
  shopType  String?  

  role      String   @default("OWNER") // "OWNER" ya "EMPLOYEE"
  shopKey   String?  @unique           // Malik ki secret chaabi (e.g., AGRO-A1B2)
  ownerId   String?                    // Agar ye employee hai, toh uske malik ki ID
  status    String    @default("ACTIVE")

  owner     User?    @relation("ShopStaff", fields: [ownerId], references: [id])
  employees User[]   @relation("ShopStaff")
  securityQuestion String?   // Jaise: "Aapke bachpan ke dost ka naam?"
  securityAnswer   String?   // Jawab (hamesha lowercase mein save karenge)

  customers Customer[]
  products  Product[]
  orders    Order[]
  purchases Purchase[]
  suppliers Supplier[]
  createdAt DateTime @default(now())
}

// ─── CUSTOMER ───
model Customer {
  id        String    @id @default(cuid())
  userId    String    // <-- HAR TABLE MEIN YEH ADD HOGA
  user      User      @relation(fields: [userId], references: [id])
  
  name      String    
  mobile    String?   
  village   String?   
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  orders    Order[]   
  payments  Payment[]
}

// ─── PRODUCT (SMART INVENTORY) ───
model Product {
  id            String         @id @default(cuid())
  userId        String         // <-- OWNER ki ID
  user          User           @relation(fields: [userId], references: [id])
  
  name          String   
  category      String   
  brand         String?  
  stockQty      Float    
  
  unit          String         // Asli base unit (KG, Ltr, Pcs)
  isPackaged    Boolean        @default(false) // Kya yeh Bag/Box mein aata hai?
  packageUnit   String?        // Bag, Box, Pkt
  qtyPerPackage Float?         // 1 Bag mein kitne KG/Ltr hain? (e.g., 50)
  
  buyPrice      Float          // Base Price (Per KG/Ltr)
  sellPrice     Float          // Base Price (Per KG/Ltr)
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  orderItems    OrderItem[] 
  purchaseItems PurchaseItem[]
  salesReturnItems SalesReturnItem[]
}

// ─── ORDER (SALE BILL) ───
model Order {
  id          String      @id @default(cuid())
  userId      String      // <-- Yeh hamesha OWNER ki ID rahegi (Master Bucket)
  user        User        @relation(fields: [userId], references: [id])
  
  // ─── NAYE TRACKING FIELDS ───
  createdById   String    @default("")      // Kisne bill kaata (Employee ID ya Owner ID)
  createdByName String    @default("Owner") // Employee ka naam jo owner ko dikhega

  customerId  String?   
  customer    Customer?   @relation(fields: [customerId], references: [id]) 
  totalAmount Float     
  paidAmount  Float     
  status      String      
  items       OrderItem[] 
  createdAt   DateTime    @default(now()) 
  updatedAt   DateTime    @updatedAt
  returns    SalesReturn[]
}

// ─── SUPPLIER ───
model Supplier {
  id        String            @id @default(uuid())
  userId    String            // <-- ISOLATION TAG
  user      User              @relation(fields: [userId], references: [id])
  
  name      String            
  company   String?           
  mobile    String
  address   String?
  createdAt DateTime          @default(now())
  purchases Purchase[]        
  payments  SupplierPayment[] 
}

// ─── PURCHASE (INWARD STOCK) ───
model Purchase {
  id          String         @id @default(uuid())
  userId      String         // <-- OWNER ki ID (Master Bucket)
  user        User           @relation(fields: [userId], references: [id])
  
  // ─── NAYE TRACKING FIELDS ───
  createdById   String       @default("")
  createdByName String       @default("Owner")

  supplierId  String
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  totalAmount Float          
  paidAmount  Float          
  status      String         
  billNumber  String?        
  createdAt   DateTime       @default(now())
  items       PurchaseItem[]
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String   
  order         Order    @relation(fields: [orderId], references: [id]) 
  productId     String   
  product       Product  @relation(fields: [productId], references: [id]) 
  
  // Base details (Real calculation ke liye)
  qty           Float    // Actual Base Unit Deduction (e.g., 0.5 KG)
  priceAtSale   Float    // Price per Base Unit
  
  // Tracking details (Parchi par dikhane ke liye)
  enteredQty    Float?   @default(0)     // Jo user ne type kiya (e.g., 500)
  enteredUnit   String?  @default("Base")// Jo unit select ki (e.g., "Gram")
  enteredPrice  Float?   // 👈 NAYA: Ek piece/bori ka sale rate
  customLabel   String?  // 👈 NAYA: Parchi par print karne wala naam
}

model Payment {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  amount      Float    
  createdAt   DateTime @default(now()) 
}

model SupplierPayment {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  amount      Float    
  createdAt   DateTime @default(now())
}

model PurchaseItem {
  id            String   @id @default(cuid())
  purchaseId    String
  productId     String
  purchase      Purchase @relation(fields: [purchaseId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])
  
  // Base details (Real calculation ke liye)
  qty           Float    
  buyPrice      Float   
  
  enteredQty    Float?   @default(0)     
  enteredUnit   String?  @default("Base")
  enteredPrice  Float?   // 👈 NAYA: Ek piece/bori ka buy rate
  customLabel   String?
}

// ─── NAYE MODELS: SAMAAN WAPSI (SALES RETURN) ───
model SalesReturn {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  
  userId        String   // Malik ki ID
  createdById   String   // Kis employee ne wapsi li
  createdByName String

  refundAmount  Float    // Kitne paise wapas kiye ya udhaar se kate
  reason        String?  // Wapsi ka kaaran
  createdAt     DateTime @default(now())

  items         SalesReturnItem[]
}

model SalesReturnItem {
  id            String   @id @default(cuid())
  returnId      String
  returnRecord  SalesReturn @relation(fields: [returnId], references: [id])
  
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  
  qty           Float    // Base quantity wapas aayi (e.g., KG mein)
  returnPrice   Float    // Jis rate par wapas liya
  enteredQty    Float?   // Parchi par dikhne wali unit (e.g., 2 Bag)
  enteredUnit   String?
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   // Shop Owner ki ID (Taaki sirf apni dukaan ke alerts dikhein)
  message     String   // Message content
  type        String   // ALERT, ANNOUNCEMENT, TRANSACTION
  createdBy   String   // Kisne banaya (Hari, Owner, ya System)
  createdAt   DateTime @default(now())
}